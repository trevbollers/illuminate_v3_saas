# =================================
# Go Participate — Youth Sports Platform
# =================================

# MongoDB — Platform database (tenants, users, plans, feature flags)
# League tenant databases: "league_<slug>" (e.g. league_midamerica_7v7)
# Org tenant databases: "org_<slug>" (e.g. org_kc_thunder)
#
# Local (docker compose up):
MONGODB_URI=mongodb://goparticipate:gp_dev@localhost:27020/goparticipate_platform?authSource=admin
# Production (Atlas):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/goparticipate_platform?retryWrites=true&w=majority

# NextAuth
NEXTAUTH_URL=http://localhost:4000
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth (optional — Sign in with Apple)
APPLE_ID=
APPLE_SECRET=

# Stripe — only need your account keys, NOT individual price IDs.
# Price IDs are stored in the Plan documents in MongoDB (set via seed or admin UI).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=Go Participate <noreply@goparticipate.com>

# SMS — Platform-level SMS delivery (pick one provider)
# Twilio:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# AWS SNS (alternative to Twilio):
# AWS_SMS_REGION=us-east-1
# AWS_SNS_SENDER_ID=GoPart

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Platform Domain — used for subdomain-based tenant routing
# Leagues: <league-slug>.goparticipate.com
# Orgs: <org-slug>.goparticipate.com
NEXT_PUBLIC_PLATFORM_DOMAIN=goparticipate.com

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:4000
NEXT_PUBLIC_ADMIN_URL=http://localhost:4001
NEXT_PUBLIC_LEAGUE_URL=http://localhost:4002
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:4003
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:4004
